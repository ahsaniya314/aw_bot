# ==========================================
# TELEGRAM BOT CONFIGURATION
# ==========================================
# Get token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_token_here

# Comma-separated list of admin user IDs
TELEGRAM_BOT_ADMIN_IDS=123456789,987654321

# Optional: Webhook configuration for cloud deployment
TELEGRAM_WEBHOOK_URL=https://your-domain.com/telegram/webhook
TELEGRAM_WEBHOOK_PATH_SECRET=your_secret_path
TELEGRAM_WEBHOOK_SECRET_TOKEN=your_secret_token

# ==========================================
# SUPABASE CONFIGURATION
# ==========================================
# Supabase project URL
SUPABASE_URL=https://your-project.supabase.co

# Supabase API key (preferably Service Role for backend)
SUPABASE_KEY=your_supabase_key

# Timeout settings (in seconds)
SUPABASE_POSTGREST_TIMEOUT=30
SUPABASE_STORAGE_TIMEOUT=20

# ==========================================
# GOOGLE SHEETS CONFIGURATION (Legacy)
# ==========================================
# Used for backward compatibility if migrating from Google Sheets
GSPREAD_SHEET_NAME=AW PRODUCTION
GSPREAD_CREDENTIALS_FILE=credentials.json
GSPREAD_BACKUP_ENABLED=true

# ==========================================
# DATABASE CONFIGURATION
# ==========================================
# SQLite: sqlite:///bot_data.db
# PostgreSQL: postgresql://user:password@localhost/dbname
DATABASE_URL=sqlite:///bot_data.db
DATABASE_ECHO=false

# ==========================================
# NLP CONFIGURATION
# ==========================================
# Model type: rule_based, distilbert, indobert
NLP_MODEL_TYPE=rule_based

# Confidence threshold (0.0-1.0)
NLP_CONFIDENCE_THRESHOLD=0.7

# Fuzzy matching threshold (0-100)
NLP_FUZZY_THRESHOLD=85

# ==========================================
# OCR CONFIGURATION
# ==========================================
# Language for OCR: en, id, etc.
OCR_LANGUAGE=en

# Enable angle detection in OCR
OCR_ANGLE_DETECTION=true

# OCR confidence threshold (0.0-1.0)
OCR_CONFIDENCE_THRESHOLD=0.5

# OCR engine to use: paddleocr or mistralocr
OCR_ENGINE=paddleocr

# Mistral API key (required for mistralocr engine)
MISTRAL_API_KEY=your_mistral_api_key_here

# Runtime image optimization for OCR
# General runtime resize threshold (used mainly for paddle/local OCR)
OCR_RUNTIME_MAX_DIM=2200
OCR_RUNTIME_JPEG_QUALITY=88
OCR_RUNTIME_PNG_COMPRESSION=3

# More aggressive optimization for Mistral OCR to reduce upload size/latency
OCR_MISTRAL_MAX_DIM=1800
OCR_MISTRAL_JPEG_QUALITY=82
OCR_MISTRAL_MAX_SOURCE_BYTES=1500000

# OCR result cache for repeated processing of the same image content
OCR_RESULT_CACHE_TTL_SECONDS=3600
OCR_RESULT_CACHE_MAX_ITEMS=64

# ==========================================
# LOGGING CONFIGURATION
# ==========================================
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log file path
LOG_FILE=logs/bot.log

# Log format: text, json
LOG_FORMAT=text

# ==========================================
# RATE LIMITING
# ==========================================
# Enable rate limiting
RATE_LIMIT_ENABLED=true

# Requests per second per user
RATE_LIMIT_REQUESTS_PER_SECOND=10

# Burst size (max requests in burst)
RATE_LIMIT_BURST_SIZE=20

# ==========================================
# CACHE CONFIGURATION
# ==========================================
# Cache time-to-live in seconds
CACHE_TTL_SECONDS=60

# Maximum cache size (number of items)
CACHE_MAX_SIZE=1000

# ==========================================
# UI CONFIGURATION
# ==========================================
# Items per page in paginated responses
ITEM_PER_PAGE=5

# Max message length for Telegram (4096 is Telegram limit)
MAX_MESSAGE_LENGTH=4096

# ==========================================
# FEATURE FLAGS
# ==========================================
# Enable OCR service
ENABLE_OCR=true

# Enable NLP service
ENABLE_NLP=true

# Enable auto-reminder service
ENABLE_AUTO_REMINDER=true

# Enable dashboard API
ENABLE_DASHBOARD=true

# ==========================================
# DEPLOYMENT CONFIGURATION
# ==========================================
# Environment: development, staging, production
ENVIRONMENT=development

# Debug mode
DEBUG=false

# Build identifier (for tracking versions)
BUILD_ID=dev-local

# Show build info in responses
SHOW_BUILD=true

# ==========================================
# FLASK API CONFIGURATION
# ==========================================
# Flask server host
FLASK_HOST=0.0.0.0

# Flask server port
FLASK_PORT=7860

# Flask debug mode
FLASK_DEBUG=false
